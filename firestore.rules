rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────────────────
    // Users can read/write only their own profile document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Progress subcollection — own data only
      match /progress/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Analytics events ───────────────────────────────────────────────────────
    // Any authenticated user (including anonymous) can create events
    // No reads allowed from client (analytics are server/console only)
    match /analyticsEvents/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['event', 'uid', 'ts']);
      allow read, update, delete: if false;
    }
  }
}
